---
import '../styles/global.css'
---

<header class="w-full bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6 h-16 grid grid-cols-3 items-center">

    
    <div class="flex justify-start">
      <a href="/" class="text-xl font-extrabold text-gray-900 flex items-baseline">
        Portfolio<span class="text-gray-400 font-medium ml-px">.</span>
      </a>
    </div>

    
    <div class="flex justify-center">
      <nav class="hidden md:flex gap-10 items-center">
        <a href="#inicio" class="text-gray-600 hover:text-gray-900 text-sm font-medium transition-colors">Inicio</a>
        
        <a href="#proyectos" class="text-gray-600 hover:text-gray-900 text-sm font-medium transition-colors">Proyectos</a>
        <a href="#habilidades" class="text-gray-600 hover:text-gray-900 text-sm font-medium transition-colors">Habilidades</a>
      </nav>
    </div>

    
    <div class="flex justify-end items-center">
      <a href="#contacto" class="inline-flex items-center justify-center bg-gray-950 text-white rounded-full px-5 py-2.5 text-sm font-semibold hover:bg-black transition-colors">
        Contacto
      </a>
    </div>

  </div>
</header>