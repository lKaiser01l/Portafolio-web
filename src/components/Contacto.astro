---
---
<section id="contacto" class="w-full bg-gray-50 py-24 px-6">
  <div class="max-w-5xl mx-auto">
    
    <div class="mb-16">
      <h2 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-4 leading-none">
        <span class="text-gray-900 block">Contactame</span>
        
      </h2>
      <p class="text-gray-600 max-w-xl leading-relaxed text-sm md:text-base">
        ¿Tienes alguna pregunta o quieres trabajar conmigo? ¡Envíame un mensaje!
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
      
      <div class="md:col-span-5 space-y-10">
        <div>
          <h3 class="text-xs font-bold text-gray-400 tracking-wider uppercase mb-3">Email</h3>
          <a href="mailto:lKaiser01ll@gmail.com" class="text-lg text-gray-900 hover:text-gray-600 transition-colors inline-flex items-center gap-2">
            lKaiser01ll@gmail.com
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>

        <div>
          <h3 class="text-xs font-bold text-gray-400 tracking-wider uppercase mb-3">Redes Sociales</h3>
          <div class="flex gap-3">
            <a href="https://github.com/lKaiser01l" target="_blank" class="w-11 h-11 rounded-lg border border-gray-200 bg-transparent flex items-center justify-center text-gray-700 hover:text-gray-900 hover:border-gray-300 transition-all" aria-label="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
            
            <a href="mailto:lKaiser01ll@gmail.com" class="w-11 h-11 rounded-lg border border-gray-200 bg-transparent flex items-center justify-center text-gray-700 hover:text-gray-900 hover:border-gray-300 transition-all" aria-label="Email">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
          </div>
        </div>

        <div>
          <h3 class="text-xs font-bold text-gray-400 tracking-wider uppercase mb-3">Ubicación</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            Lima, Perú<br/>
            Disponible para proyectos remotos
          </p>
        </div>
      </div>

      <div class="md:col-span-7">
        <form class="flex flex-col gap-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="nombre" class="block text-xs font-semibold text-gray-700 mb-2">Nombre</label>
              <input type="text" id="nombre" placeholder="Tu nombre" class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-transparent focus:border-gray-900 focus:ring-1 focus:ring-gray-900 outline-none transition-all text-sm" />
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold text-gray-700 mb-2">Email</label>
              <input type="email" id="email" placeholder="tu@email.com" class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-transparent focus:border-gray-900 focus:ring-1 focus:ring-gray-900 outline-none transition-all text-sm" />
            </div>
          </div>

          <div>
            <label for="mensaje" class="block text-xs font-semibold text-gray-700 mb-2">Mensaje</label>
            <textarea id="mensaje" placeholder="Cuéntame sobre tu proyecto..." rows="5" class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-transparent focus:border-gray-900 focus:ring-1 focus:ring-gray-900 outline-none transition-all text-sm resize-none"></textarea>
          </div>

          <button type="submit" class="mt-2 w-full inline-flex items-center justify-center bg-[#18181b] text-white rounded-full px-6 py-4 text-sm font-semibold hover:bg-black transition-colors">
            Enviar mensaje
          </button>
        </form>
      </div>

    </div>
  </div>
</section>