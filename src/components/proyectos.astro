---
// Proyectos.astro

const proyectos = [
  
  
  {
    titulo: "Pv Electrónica",
    descripcion: "Desarrollo de sitio web para una empresa de electrónica con enfoque en diseño moderno y funcionalidad.",
    tags: ["Css", "Html", "JavaScript", "PHP", "Web"],
    imagen: "/image.png",
    
    linkDemo: "https://pvelectronica.consigueventas.com/"
  },
  {
    titulo: "Agencia Online JF",
    descripcion: "Desarrollo de sitio web para una agencia de servicios digitales con un diseño atractivo y fácil navegación.",
    tags: ["WordPress", "PHP", "Web"],
    imagen: "/wor.png",
    
    linkDemo: "https://soyjhoelfernandez.com/inicio-copy/"
  },
  {
    titulo: "Cosmic Virtual Projects",
    descripcion: "Desarrollo de sitio web y marca digital con un enfoque en alto rendimiento y diseño moderno.",
    tags: ["Astro", "React" , "Tailwind CSS", "Web"],
    imagen: "/Cosmi.png",
    
    linkDemo: "https://www.cosmicvirtualprojects.com/"
  },
  {
    titulo: "Reposteria Las Delicias",
    descripcion: "Desarrolo de un sistemas web para la gestión de pedidos y catálogo de productos para una repostería",
    tags: ["Astro", "Bootstrap", "JavaScript", "Spring Boot", "Web"],
    imagen: "/Reposteria.png",
    linkCodigo: "https://github.com/lKaiser01l/reposteria",
    linkDemo: "https://reposteria-jet.vercel.app/"
  },
  
  
];
---

<section id="proyectos" class="w-full bg-gray-50 py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Encabezado de la sección -->
    <div class="text-center mb-16">
      <h2 class="text-4xl font-extrabold text-gray-900 mb-4">Proyectos</h2>
      <p class="text-lg text-gray-500">Algunos de mis trabajos recientes</p>
    </div>

    <!-- Grid de Proyectos -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {proyectos.map((proyecto) => (
        <article class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
          <!-- Imagen del proyecto -->
          <div class="h-48 overflow-hidden bg-gray-100">
            <img 
              src={proyecto.imagen} 
              alt={`Imagen de ${proyecto.titulo}`} 
              class="w-full h-full object-cover" 
            />
          </div>

          <!-- Contenido de la tarjeta -->
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-xl font-bold text-gray-900 mb-2">{proyecto.titulo}</h3>
            <p class="text-gray-600 text-sm mb-6 flex-grow leading-relaxed">
              {proyecto.descripcion}
            </p>

            <!-- Etiquetas de tecnologías -->
            <div class="flex flex-wrap gap-2 mb-6">
              {proyecto.tags.map((tag) => (
                <span class="bg-blue-50 text-blue-600 text-xs font-semibold px-3 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Enlaces -->
            <div class="flex gap-4 text-sm font-medium">
                {proyecto.linkCodigo && (
                <a href={proyecto.linkCodigo} class="flex items-center gap-1.5 text-gray-600 hover:text-gray-900 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                    Código
                </a>
                )}
              <a href={proyecto.linkDemo} class="flex items-center gap-1.5 text-gray-600 hover:text-gray-900 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Link
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>